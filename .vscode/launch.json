{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Mock Device",
            "type": "debugpy",
            "request": "launch",
            "module": "app.device.main"
        },
        {
            "name": "Broker Service",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.broker.main:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "9000"
            ],
            "envFile": "${workspaceFolder}/.env",
            "jinja": true
        },
    ]
}